# Ignore bundler config
/.bundle

# Ignore the build directory
/pkg

# Ignore bundler gems
/vendor

# Ignore all logfiles and tempfiles
/log/*
/tmp/*
!/log/.keep
!/tmp/.keep

# Ignore pidfiles, but keep the directory
/tmp/pids/*
!/tmp/pids/.keep

# Ignore uploaded files in development
/storage/*
!/storage/.keep

# Ignore master key for decrypting credentials
/config/master.key

# Ignore dotenv files
.env
.env.*

# Ignore coverage reports
/coverage

# Ignore IDE files
.idea
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# Ignore OS files
.DS_Store
Thumbs.db

# Ignore gem files
*.gem

# Ignore rspec state
.rspec_status

# Ignore byebug history
.byebug_history

# Ignore ruby-version managers
.ruby-gemset
.tool-versions

# Ignore test database
*.sqlite3
*.sqlite3-journal

# Ignore generated documentation
/doc
.yardoc

# Ignore simplecov
coverage/

# Ignore CI artifacts
/test-results/
